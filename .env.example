# ===========================
# LLM Provider Configuration
# ===========================

# Choose ONE provider (Vision Agents recommended for hackathon)

# Option 1: Vision Agents (Stream Vision AI - Sponsor!)
# Best for: Real-time video AI, low latency, hackathon demos
USE_VISION_AGENTS=false
VISION_AGENT_URL=http://127.0.0.1:8765

# Option 2: Google Gemini (Cloud)
# Best for: High accuracy, no local setup
GEMINI_API_KEY=your_gemini_api_key_here

# Option 3: Ollama (Local/Private)
# Best for: Privacy, offline use
USE_OLLAMA=false
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# ===========================
# Stream API (for Vision Agents)
# ===========================
# Get free API key at https://getstream.io/
# 333,000 free participant minutes/month
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# ===========================
# Optional: Voice Features
# ===========================
# For Vision Agents voice capabilities
ELEVENLABS_API_KEY=your_elevenlabs_key
DEEPGRAM_API_KEY=your_deepgram_key
